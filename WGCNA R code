# Create a function to add dup suffix
rename_duplicates <- function(df) {
  # Create a counter for each Feature
  df <- df %>%
    group_by(Feature) %>%
    mutate(
      dup_count = sequence(n()),
      Feature = case_when(
        n() == 1 ~ Feature,  # If no duplicates, keep original name
        dup_count == 1 ~ Feature,  # First instance keeps original name
        dup_count == 2 ~ paste0(Feature, "_dup"),  # First duplicate
        TRUE ~ paste0(Feature, "_dup_", dup_count - 1)  # Additional duplicates
      )
    ) %>%
    ungroup() %>%
    select(-dup_count)  # Remove the counter column
  
  return(df)
}

