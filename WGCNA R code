create_module_plot <- function(module_name, module_genes, module_color) {
  
  # Add MM for this module for ALL genes
  plot_data <- all_gene_data
  plot_data$MM <- abs(as.numeric(module_membership_measure[paste0("ME", module_name), ]))
  plot_data$inModule <- plot_data$gene %in% module_genes
  plot_data$isHub    <- plot_data$inModule & plot_data$MM > 0.8 & plot_data$GS > 0.4
  
  n_hub   <- sum(plot_data$isHub)
  n_total <- sum(plot_data$inModule)
  
  p <- ggplot(plot_data, aes(x = MM, y = GS)) +
    geom_vline(xintercept = 0.8, linetype = "dashed", color = "gray60") +
    geom_hline(yintercept = 0.4, linetype = "dashed", color = "gray60") +
    # Background: all non-module genes
    geom_point(data = plot_data[!plot_data$inModule, ],
               color = "grey80", alpha = 0.4, size = 1) +
    # Module genes (non-hub)
    geom_point(data = plot_data[plot_data$inModule & !plot_data$isHub, ],
               color = module_color, alpha = 0.6, size = 1.8) +
    # Hub genes
    geom_point(data = plot_data[plot_data$isHub, ],
               color = "red", alpha = 0.9, size = 1.8) +
    annotate("text", x = Inf, y = Inf,
             label = paste0("Hub genes: ", n_hub, "/", n_total),
             hjust = 1.1, vjust = 1.5, size = 3.5, color = "gray30") +
    labs(
      title = paste0(module_name, " module"),
      x = "Module membership",
      y = "Gene significance"
    ) +
    scale_x_continuous(limits = c(0, 1), breaks = seq(0, 1, 0.2)) +
    scale_y_continuous(limits = c(0, 0.8), breaks = seq(0, 0.8, 0.2)) +
    theme_minimal(base_size = 11) +
    theme(
      plot.title = element_text(size = 12, face = "bold"),
      axis.title = element_text(size = 9),
      axis.text = element_text(size = 8),
      panel.grid.minor = element_blank()
    )
  
  return(p)
}

