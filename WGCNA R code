# Function to create module data with multiple hub thresholds
create_module_table <- function(module_name, module_genes, module_color) {
  # Fix gene significance data handling
  gs_vector <- as.vector(gene_significance_corr)
  names(gs_vector) <- rownames(gene_significance_corr)
  
  gs_pvalue_vector <- as.vector(gene_significance_corr_pvals)
  names(gs_pvalue_vector) <- rownames(gene_significance_corr_pvals)
  
  # Create data frame for module genes
  module_data <- data.frame(
    gene = module_genes,
    module = module_name,
    moduleColor = module_color,
    MM = abs(as.numeric(module_membership_measure[paste0("ME", module_name), module_genes])),
    MM_pvalue = as.numeric(module_membership_measures_pvals[paste0("ME", module_name), module_genes]),
    GS = abs(as.numeric(gs_vector[module_genes])),
    GS_pvalue = as.numeric(gs_pvalue_vector[module_genes])
  )
  
  # Add hub gene classifications with proper TRUE/FALSE values
  module_data$hub_strict <- with(module_data, MM > 0.8 & GS > 0.4)
  module_data$hub_medium <- with(module_data, MM > 0.8 & GS > 0.35)
  module_data$hub_relaxed <- with(module_data, MM > 0.8 & GS > 0.3)
  
  # Add combined score and sort
  module_data$combinedScore <- module_data$MM * module_data$GS
  module_data <- module_data[order(-module_data$combinedScore), ]
  
  return(module_data)
}

